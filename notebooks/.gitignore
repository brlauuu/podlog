# Issue #607: only the curated examples are checked in. User scratch work
# (and Jupyter checkpoints) stay local.
*
!.gitignore
!examples/
!examples/**
!lib/
!lib/**
.ipynb_checkpoints/

# Issue #748: `jupyter nbconvert --to html` writes alongside the .ipynb
# source. Keep those build artifacts out of git status.
examples/*.html
examples/_*.html

